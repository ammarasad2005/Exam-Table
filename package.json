{
  "name": "fsc-exams",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "ts-node scripts/parse-excel.ts",
    "build": "next build",
    "dev": "npm run prebuild && next dev",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "lint": "next lint",
    "timetable:update": "python3 all_courses_schedule.py && mkdir -p public/data && cp timetable.json public/data/timetable.json",
    "events:scrape": "python3 scripts/scrape_slate.py",
    "events:filter": "python3 scripts/filter_events.py",
    "events:update": "npm run events:scrape && npm run events:filter"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "eslint": "^8",
    "eslint-config-next": "^14",
    "playwright": "^1.59.1",
    "postcss": "^8",
    "tailwindcss": "^3.4",
    "ts-node": "^10",
    "typescript": "^5"
  }
}
